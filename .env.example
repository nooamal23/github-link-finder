# Copy to .env (same directory as docker-compose.yml) and set a real value
# BEFORE the first `docker compose up`. Generate one with:
#   openssl rand -base64 24
#
# This value is used by:
#   - the `db` service as POSTGRES_PASSWORD
#   - the `api` service via backend/.env's DATABASE_URL (must match!)
POSTGRES_PASSWORD=change-me
