// Prisma schema for منصة فرع سيدي الهاني
// Apply changes with: `npm run db:push` (dev) or `npm run migrate` (prod).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  instructor
  student

  @@map("user_role")
}

enum CourseCategory {
  children
  women
  men
  training
  summer

  @@map("course_category")
}

enum BoardPosition {
  president
  vice_president
  secretary
  treasurer
  member

  @@map("board_position")
}

enum AgeCategory {
  under_9
  age_9_to_15
  over_15

  @@map("age_category")
}

enum RegistrationRequestStatus {
  pending
  approved
  rejected

  @@map("registration_request_status")
}


model User {
  id            String    @id @default(uuid()) @db.Uuid
  username      String    @unique
  passwordHash  String    @map("password_hash")
  fullName      String    @map("full_name")
  role          UserRole
  phone         String?
  birthDate     DateTime? @map("birth_date") @db.Date
  photoUrl      String?   @map("photo_url")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  coursesTaught   Course[]         @relation("Instructor")
  enrollments     Enrollment[]
  attendance      Attendance[]
  evaluations     Evaluation[]
  financeEntries  FinanceEntry[]
  sentMessages    Message[]        @relation("MessagesFrom")
  receivedMessages Message[]       @relation("MessagesTo")
  resolvedRegistrationRequests RegistrationRequest[] @relation("ResolvedRegistrationRequests")

  @@map("users")
}

model Season {
  id       Int       @id @default(autoincrement())
  name     String
  startsOn DateTime  @map("starts_on") @db.Date
  endsOn   DateTime  @map("ends_on")   @db.Date
  courses  Course[]

  @@map("seasons")
}

model Course {
  id           String          @id @default(uuid()) @db.Uuid
  seasonId     Int?            @map("season_id")
  title        String
  category     CourseCategory
  level        String
  schedule     String
  capacity     Int             @default(25)
  instructorId String?         @map("instructor_id") @db.Uuid
  isPublished  Boolean         @default(true) @map("is_published")
  startDate    DateTime?       @map("start_date") @db.Date
  endDate      DateTime?       @map("end_date") @db.Date
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  season       Season?         @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  instructor   User?           @relation("Instructor", fields: [instructorId], references: [id], onDelete: SetNull)
  enrollments  Enrollment[]
  attendance   Attendance[]
  evaluations  Evaluation[]

  @@map("courses")
}

model Enrollment {
  id         String    @id @default(uuid()) @db.Uuid
  courseId   String    @map("course_id") @db.Uuid
  studentId  String    @map("student_id") @db.Uuid
  enrolledAt DateTime  @default(now()) @map("enrolled_at") @db.Timestamptz(6)

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
  @@index([courseId])
  @@index([studentId])
  @@map("enrollments")
}

model Attendance {
  id          String   @id @default(uuid()) @db.Uuid
  courseId    String   @map("course_id") @db.Uuid
  studentId   String   @map("student_id") @db.Uuid
  sessionDate DateTime @map("session_date") @db.Date
  present     Boolean
  note        String?

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId, sessionDate])
  @@index([courseId, sessionDate])
  @@map("attendance")
}

model Evaluation {
  id           String   @id @default(uuid()) @db.Uuid
  courseId     String   @map("course_id") @db.Uuid
  studentId    String   @map("student_id") @db.Uuid
  label        String
  score        Decimal  @db.Decimal(5, 2)
  maxScore     Decimal  @default(20) @map("max_score") @db.Decimal(5, 2)
  evaluatedAt  DateTime @default(now()) @map("evaluated_at") @db.Date

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("evaluations")
}

model News {
  id            String   @id @default(uuid()) @db.Uuid
  title         String
  excerpt       String
  body          String
  tag           String
  dateGregorian String   @map("date_gregorian")
  dateHijri     String   @map("date_hijri")
  publishedAt   DateTime @default(now()) @map("published_at") @db.Timestamptz(6)

  @@index([publishedAt(sort: Desc)])
  @@map("news")
}

model Competition {
  id           String @id @default(uuid()) @db.Uuid
  name         String
  level        String
  year         Int
  participants Int    @default(0)
  passed       Int    @default(0)
  topThree     Json   @default("[]") @map("top_three")

  @@map("competitions")
}

model Gallery {
  id    String @id @default(uuid()) @db.Uuid
  title String
  date  String
  url   String

  @@map("gallery")
}

model BoardMember {
  id         String        @id @default(uuid()) @db.Uuid
  fullName   String        @map("full_name")
  birthDate  DateTime?     @map("birth_date") @db.Date
  phone      String?
  position   BoardPosition
  photoUrl   String?       @map("photo_url")
  orderIndex Int           @default(0) @map("order_index")
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([orderIndex])
  @@map("board_members")
}

model FinanceEntry {
  id          String   @id @default(uuid()) @db.Uuid
  kind        String
  category    String
  amount      Decimal  @db.Decimal(12, 3)
  description String?
  entryDate   DateTime @default(now()) @map("entry_date") @db.Date
  createdById String?  @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@map("finance_entries")
}

model Message {
  id         String    @id @default(uuid()) @db.Uuid
  fromUserId String    @map("from_user") @db.Uuid
  toUserId   String    @map("to_user")   @db.Uuid
  body       String
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  readAt     DateTime? @map("read_at") @db.Timestamptz(6)

  fromUser User @relation("MessagesFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("MessagesTo",   fields: [toUserId],   references: [id], onDelete: Cascade)

  @@map("messages")
}

model RegistrationRequest {
  id           String                     @id @default(uuid()) @db.Uuid
  fullName     String                     @map("full_name")
  ageCategory  AgeCategory                @map("age_category")
  phone        String
  status       RegistrationRequestStatus  @default(pending)
  createdAt    DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt   DateTime?                  @map("resolved_at") @db.Timestamptz(6)
  resolvedById String?                    @map("resolved_by") @db.Uuid

  resolvedBy User? @relation("ResolvedRegistrationRequests", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@map("registration_requests")
}
