# Backend env — copy to backend/.env and edit for your environment.
PORT=4000
NODE_ENV=production

# Postgres (matches docker-compose service name)
DATABASE_URL=postgres://app:app_password@db:5432/sidi_elhani

# JWT signing key — generate a long random string in production.
# Example: `openssl rand -hex 48`
JWT_SECRET=replace-with-a-long-random-secret

# Allowed origins for CORS (comma-separated, no spaces).
# NEVER use '*' here — the API sends credentials, which requires an explicit list.
# For local development, http://localhost:3000 is enabled by default.
# For production, REPLACE with your real domain(s), e.g.
#   CORS_ORIGINS=https://sidi-elhani.tn,https://www.sidi-elhani.tn
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Optional: fix the initial admin password for `npm run seed`.
# If unset, a strong random password is generated and printed ONCE at seed time.
# SEED_ADMIN_PASSWORD=

# ---- Finance module second-factor ----
# The finance section requires a SEPARATE password on top of admin login.
# Generate the bcrypt hash with:
#   node backend/scripts/hash-finance-password.js "your-finance-password"
# The script prints TWO forms — use the one labeled "For backend/.env" below.
#
# !!! IMPORTANT — Docker Compose $-interpolation warning !!!
# This file is loaded via docker-compose `env_file:`, and Compose interpolates
# `$VAR` / `${VAR}` inside env_file values. Bcrypt hashes contain literal `$`
# characters (e.g. `$2a$10$mBU...`), so you MUST double every `$` here
# (e.g. `$2a$10$` becomes `$$2a$$10$$`) or the hash will be silently corrupted
# and finance unlock will always report "wrong password" with no other clue.
# The hash script prints the already-doubled version — copy that one.
#
# Example (already $-doubled, safe for this file):
#   FINANCE_PASSWORD_HASH=$$2a$$10$$mBU.iq281AjZexampleexampleexampleexampleexampleexampleexa
#
# If unset, POST /api/admin/finance/unlock returns 500 and finance stays locked.
FINANCE_PASSWORD_HASH=
